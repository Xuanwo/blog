---
import { getTranslation, loadSite } from '../lib/site-data'
import LucideIcon from './LucideIcon.astro'
import LangToggle from './LangToggle.astro'
import ThemeToggle from './ThemeToggle.astro'

const site = loadSite()
const nav = (site.menu.footer ?? []).slice().sort((a, b) => (a.weight ?? 0) - (b.weight ?? 0))
const icons = (site.menu.icon ?? []).slice().sort((a, b) => (a.weight ?? 0) - (b.weight ?? 0))

const isExternal = (url: string) => /^https?:\/\//.test(url)
---

<header class="xw-header">
  <div class="xw-header__inner">
    <a href="/" class="xw-header__brand" aria-label="Home">
      <img
        class="xw-header__avatar"
        src="/img/logo/logo.jpeg"
        alt="Xuanwo"
        width="36"
        height="36"
        decoding="async"
      />
    </a>
    <nav class="xw-header__nav" aria-label="Sections">
      {nav.map((item) => (
        <a href={item.url}>{getTranslation(item.name)}</a>
      ))}
    </nav>
    <div class="xw-header__actions">
      {icons.map((item) => (
        <a
          class="xw-icon-btn"
          href={item.url}
          aria-label={item.name}
          target={isExternal(item.url) ? '_blank' : null}
          rel={isExternal(item.url) ? 'noopener noreferrer' : null}
        >
          <LucideIcon name={item.name} />
        </a>
      ))}
      <LangToggle />
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  .xw-header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .xw-header__inner {
    width: 100%;
    max-width: var(--container);
    margin-inline: auto;
    min-height: 60px;
    padding: 0 var(--space-5);
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }
  .xw-header__nav {
    display: flex;
    align-items: center;
    gap: 2px;
    flex-wrap: wrap;
    margin-left: var(--space-2);
  }
  .xw-header__nav a {
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    color: var(--fg-subtle);
    padding: 6px 10px;
    border-radius: var(--radius-sm);
    text-transform: capitalize;
    transition: var(--transition-colors);
  }
  .xw-header__nav a:hover {
    color: var(--fg);
    background: var(--surface-2);
    text-decoration: none;
  }
  .xw-header__actions {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 2px;
    flex: none;
  }
  @media (max-width: 760px) {
    .xw-header__nav { display: none; }
  }
</style>
