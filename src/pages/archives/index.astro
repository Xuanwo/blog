---
export const prerender = true

import BaseLayout from '../../layouts/BaseLayout.astro'
import { getTranslation, loadContentIndex } from '../../lib/site-data'

const { pages } = await loadContentIndex()
const articles = pages.filter((p) => p.type !== 'page' && p.date)

function years(list: typeof articles) {
  return Array.from(
    new Set(list.map((p) => new Date(p.date as string).getUTCFullYear()))
  ).sort((a, b) => b - a)
}

const panes = [
  { lang: 'zh', years: years(articles.filter((p) => p.lang === 'zh')) },
  { lang: 'en', years: years(articles.filter((p) => p.lang === 'en')) }
]
---

<BaseLayout title={getTranslation('archives')} urlPath="/archives/">
  <div class="xw-container xw-page">
    <header class="xw-page-head">
      <h1 class="xw-page-title">{getTranslation('archives')}</h1>
    </header>
    {panes.map((pane) => (
      <div data-lang-pane={pane.lang}>
        {pane.years.length > 0 ? (
          <div class="xw-cloud">
            {pane.years.map((y) => (
              <a class="xw-cloud__item xw-mono" href={`/${y}`}>{y}</a>
            ))}
          </div>
        ) : (
          <p class="xw-empty">No posts in this language yet.</p>
        )}
      </div>
    ))}
  </div>
</BaseLayout>
