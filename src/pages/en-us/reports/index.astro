---
export const prerender = true

import BaseLayout from '../../../layouts/BaseLayout.astro'
import LangPanes from '../../../components/LangPanes.astro'
import { loadContentIndex } from '../../../lib/site-data'
import { paginate, slicePage } from '../../../lib/pagination'

const legacy = await loadContentIndex()
const { site, pageByUrl, branches } = legacy

const branchKey = 'en-us/reports'
const urls = branches[branchKey] ?? []
const items = urls.map((u) => pageByUrl.get(u)).filter(Boolean)

const meta = legacy.site.indexMeta[branchKey] ?? {}
const title = meta.title ?? 'Reports'
const description = meta.description ?? ''

const pageSize = site.pagination ?? 10
const zhItems = items.filter((p) => p?.lang === 'zh')
const enItems = items.filter((p) => p?.lang === 'en')
const current = 1
const { totalPages: zhTotal } = paginate(zhItems, pageSize)
const { totalPages: enTotal } = paginate(enItems, pageSize)
const zhList = slicePage(zhItems, pageSize, current)
const enList = slicePage(enItems, pageSize, current)
---

<BaseLayout title={title} urlPath="/en-us/reports/">
  <div class="xw-container xw-page">
    <header class="xw-page-head">
      <h1 class="xw-page-title">{title}</h1>
      {description && <p class="xw-page-sub">{description}</p>}
    </header>
    <LangPanes
      zhList={zhList}
      enList={enList}
      zhTotal={zhTotal}
      enTotal={enTotal}
      current={current}
      hrefForPage={(page) => (page <= 1 ? `/en-us/reports/` : `/en-us/reports/page/${page}/`)}
    />
  </div>
</BaseLayout>
