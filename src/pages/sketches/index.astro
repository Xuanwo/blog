---
export const prerender = true

import BaseLayout from '../../layouts/BaseLayout.astro'
import { getSortedSketches, sketchUrl } from '../../data/sketches'

const title = 'Sketches'
const description = 'Self-contained HTML sketches, diagrams, and visual notes.'
const list = getSortedSketches()

function formatSketchDate(date: string) {
  const parsed = new Date(date)
  if (Number.isNaN(parsed.getTime())) return date
  return new Intl.DateTimeFormat('en-US', {
    year: 'numeric',
    month: 'short',
    day: '2-digit',
    timeZone: 'UTC'
  }).format(parsed)
}
---

<BaseLayout title={title} urlPath="/sketches/" ogTitle={title} ogDescription={description}>
  <div class="xw-container xw-page">
    <header class="xw-page-head">
      <h1 class="xw-page-title">{title}</h1>
      <p class="xw-page-sub">{description}</p>
    </header>

    {list.length === 0 && <p class="xw-empty">No sketches yet.</p>}

    {list.length > 0 && (
      <ul class="xw-sketches">
        {list.map((sketch) => (
          <li class="xw-sketches__item">
            {sketch.cover && (
              <a class="xw-sketches__cover" href={sketchUrl(sketch)} aria-label={sketch.title}>
                <img src={sketch.cover} alt="" loading="lazy" />
              </a>
            )}
            <div class="xw-sketches__body">
              <time class="xw-mono xw-sketches__date" datetime={sketch.date}>
                {formatSketchDate(sketch.date)}
              </time>
              <h2 class="xw-sketches__title">
                <a href={sketchUrl(sketch)}>{sketch.title}</a>
              </h2>
              {sketch.description && <p class="xw-sketches__desc">{sketch.description}</p>}
            </div>
          </li>
        ))}
      </ul>
    )}
  </div>
</BaseLayout>

<style>
  .xw-sketches { list-style: none; margin: 0; padding: 0; }
  .xw-sketches__item {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    padding: var(--space-6) 0;
    border-bottom: 1px solid var(--border);
  }
  .xw-sketches__cover img {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }
  .xw-sketches__date { font-size: var(--text-sm); color: var(--fg-subtle); }
  .xw-sketches__title {
    margin: var(--space-1) 0 0;
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-snug);
  }
  .xw-sketches__title a { color: var(--fg); }
  .xw-sketches__title a:hover { color: var(--accent-text); }
  .xw-sketches__desc {
    margin: var(--space-2) 0 0;
    color: var(--fg-subtle);
    line-height: var(--leading-normal);
  }
  @media (min-width: 640px) {
    .xw-sketches__item--cover { grid-template-columns: 4fr 8fr; }
  }
  .xw-sketches__item:has(.xw-sketches__cover) {
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) {
    .xw-sketches__item:has(.xw-sketches__cover) {
      grid-template-columns: 320px 1fr;
      align-items: start;
    }
  }
</style>
