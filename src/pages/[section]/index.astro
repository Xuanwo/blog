---
export const prerender = true

import BaseLayout from '../../layouts/BaseLayout.astro'
import LangPanes from '../../components/LangPanes.astro'
import {
  loadContentIndex,
  pluralizeTitle,
  titleizeSegmentPreserve
} from '../../lib/site-data'
import { paginate, slicePage } from '../../lib/pagination'

const { site, pageByUrl, sections, sectionsMeta } = await loadContentIndex()
const indexMeta = site.indexMeta

export async function getStaticPaths() {
  const { sections } = await loadContentIndex()
  return Object.keys(sections).map((section) => ({ params: { section } }))
}

const section = String(Astro.params.section)
const urls = sections[section] ?? []
const items = urls.map((u) => pageByUrl.get(u)).filter(Boolean)
const pageSize = site.pagination ?? 10

const zhItems = items.filter((p) => p?.lang === 'zh')
const enItems = items.filter((p) => p?.lang === 'en')
const current = 1
const { totalPages: zhTotal } = paginate(zhItems, pageSize)
const { totalPages: enTotal } = paginate(enItems, pageSize)
const zhList = slicePage(zhItems, pageSize, current)
const enList = slicePage(enItems, pageSize, current)

const meta = indexMeta[section]
const display = sectionsMeta[section]?.display ?? section
const title = meta?.title ?? pluralizeTitle(titleizeSegmentPreserve(display))
const description = meta?.description ?? ''
const urlPath = `/${section}/`
---

<BaseLayout title={title} urlPath={urlPath}>
  <div class="xw-container xw-page">
    <header class="xw-page-head">
      <h1 class="xw-page-title">{title}</h1>
      {description && <p class="xw-page-sub">{description}</p>}
    </header>
    <LangPanes
      zhList={zhList}
      enList={enList}
      zhTotal={zhTotal}
      enTotal={enTotal}
      current={current}
      hrefForPage={(page) => (page <= 1 ? `/${section}/` : `/${section}/page/${page}/`)}
    />
  </div>
</BaseLayout>
