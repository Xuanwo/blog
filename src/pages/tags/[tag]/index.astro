---
export const prerender = true

import BaseLayout from '../../../layouts/BaseLayout.astro'
import LangPanes from '../../../components/LangPanes.astro'
import { loadContentIndex } from '../../../lib/site-data'
import { paginate, slicePage } from '../../../lib/pagination'

const legacy = await loadContentIndex()
const pageSize = legacy.site.pagination ?? 10

export async function getStaticPaths() {
  const legacy = await loadContentIndex()
  return Object.keys(legacy.taxonomies.tags).map((slug) => ({ params: { tag: slug } }))
}

const slug = String(Astro.params.tag)

const entry = legacy.taxonomies.tags[slug]
if (!entry) throw new Error(`Missing tag: ${slug}`)

const urls = entry.pages ?? []
const items = urls.map((u) => legacy.pageByUrl.get(u)).filter(Boolean)
const zhItems = items.filter((p) => p?.lang === 'zh')
const enItems = items.filter((p) => p?.lang === 'en')
const current = 1
const { totalPages: zhTotal } = paginate(zhItems, pageSize)
const { totalPages: enTotal } = paginate(enItems, pageSize)
const zhList = slicePage(zhItems, pageSize, current)
const enList = slicePage(enItems, pageSize, current)
---

<BaseLayout title={entry.name} urlPath={`/tags/${slug}/`}>
  <div class="xw-container xw-page">
    <header class="xw-page-head">
      <p class="xw-eyebrow">Tag</p>
      <h1 class="xw-page-title">#{entry.name}</h1>
    </header>
    <LangPanes
      zhList={zhList}
      enList={enList}
      zhTotal={zhTotal}
      enTotal={enTotal}
      current={current}
      hrefForPage={(page) => (page <= 1 ? `/tags/${slug}/` : `/tags/${slug}/page/${page}/`)}
    />
  </div>
</BaseLayout>
