---
export const prerender = true

import BaseLayout from '../../layouts/BaseLayout.astro'
import LangPanes from '../../components/LangPanes.astro'
import { loadContentIndex } from '../../lib/site-data'
import { paginate, slicePage } from '../../lib/pagination'

const { site, pages } = await loadContentIndex()
const pageSize = site.pagination ?? 10
const regularPages = pages.filter((p) => p.type !== 'page')
const zhPages = regularPages.filter((p) => p.lang === 'zh')
const enPages = regularPages.filter((p) => p.lang === 'en')

export async function getStaticPaths() {
  const { site, pages } = await loadContentIndex()
  const pageSize = site.pagination ?? 10
  const regular = pages.filter((p) => p.type !== 'page')
  // Route count = mixed page count, so every legacy /page/N/ stays 200.
  // Each pane slices its own language; out-of-range pages show empty state.
  const totalPages = paginate(regular, pageSize).totalPages
  return Array.from({ length: totalPages }, (_, idx) => ({ params: { page: String(idx + 1) } }))
}

const current = Number(Astro.params.page)
const { totalPages: zhTotal } = paginate(zhPages, pageSize)
const { totalPages: enTotal } = paginate(enPages, pageSize)
const zhList = slicePage(zhPages, pageSize, current)
const enList = slicePage(enPages, pageSize, current)
const urlPath = current <= 1 ? '/' : `/page/${current}/`
---

<BaseLayout title={site.title} urlPath={urlPath}>
  <div class="xw-container xw-page">
    <header class="xw-page-head">
      <div data-lang-pane="zh"><h1 class="xw-page-title">{site.i18nZh.site_title ?? site.title}</h1></div>
      <div data-lang-pane="en"><h1 class="xw-page-title">{site.title}</h1></div>
    </header>
    <LangPanes
      zhList={zhList}
      enList={enList}
      zhTotal={zhTotal}
      enTotal={enTotal}
      current={current}
      hrefForPage={(page) => (page <= 1 ? '/' : `/page/${page}/`)}
    />
  </div>
</BaseLayout>
