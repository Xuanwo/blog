---
export const prerender = true

import BaseLayout from '../../../../layouts/BaseLayout.astro'
import LangPanes from '../../../../components/LangPanes.astro'
import { loadContentIndex } from '../../../../lib/site-data'
import { paginate, slicePage } from '../../../../lib/pagination'

const legacy = await loadContentIndex()
const { site, pageByUrl } = legacy
const pageSize = site.pagination ?? 10

export async function getStaticPaths() {
  const legacy = await loadContentIndex()
  const pageSize = legacy.site.pagination ?? 10
  const paths = []
  for (const slug of Object.keys(legacy.taxonomies.series)) {
    const meta = legacy.site.indexMeta[`series/${slug}`] ?? {}
    const urls = legacy.taxonomies.series[slug]?.pages ?? []
    const items = urls.map((u) => legacy.pageByUrl.get(u)).filter(Boolean)
    const totalPages = paginate(items, pageSize).totalPages
    for (let p = 1; p <= totalPages; p++) {
      paths.push({ params: { series: slug, page: String(p) }, props: { meta } })
    }
  }
  return paths
}

const meta = (Astro.props.meta ?? {}) as { title?: string; description?: string }
const slug = String(Astro.params.series)
const current = Number(Astro.params.page)

const entry = legacy.taxonomies.series[slug]
if (!entry) throw new Error(`Missing series: ${slug}`)
const urls = entry.pages ?? []
const items = urls.map((u) => pageByUrl.get(u)).filter(Boolean)
const zhItems = items.filter((p) => p?.lang === 'zh')
const enItems = items.filter((p) => p?.lang === 'en')
const { totalPages: zhTotal } = paginate(zhItems, pageSize)
const { totalPages: enTotal } = paginate(enItems, pageSize)
const zhList = slicePage(zhItems, pageSize, current)
const enList = slicePage(enItems, pageSize, current)

const title = meta.title ?? entry.name
const description = meta.description ?? ''
---

<BaseLayout
  title={title}
  urlPath={current <= 1 ? `/series/${slug}/` : `/series/${slug}/page/${current}/`}
>
  <div class="xw-container xw-page">
    <header class="xw-page-head">
      <p class="xw-eyebrow">Series</p>
      <h1 class="xw-page-title">{title}</h1>
      {description && <p class="xw-page-sub">{description}</p>}
    </header>
    <LangPanes
      zhList={zhList}
      enList={enList}
      zhTotal={zhTotal}
      enTotal={enTotal}
      current={current}
      hrefForPage={(page) => (page <= 1 ? `/series/${slug}/` : `/series/${slug}/page/${page}/`)}
    />
  </div>
</BaseLayout>
