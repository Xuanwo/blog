---
export const prerender = true

import BaseLayout from '../../../../layouts/BaseLayout.astro'
import LangPanes from '../../../../components/LangPanes.astro'
import { loadContentIndex } from '../../../../lib/site-data'
import { paginate, slicePage } from '../../../../lib/pagination'

const legacy = await loadContentIndex()
const pageSize = legacy.site.pagination ?? 10

export async function getStaticPaths() {
  const legacy = await loadContentIndex()
  const pageSize = legacy.site.pagination ?? 10
  const paths = []
  for (const slug of Object.keys(legacy.taxonomies.categories)) {
    const urls = legacy.taxonomies.categories[slug]?.pages ?? []
    const items = urls.map((u) => legacy.pageByUrl.get(u)).filter(Boolean)
    const totalPages = paginate(items, pageSize).totalPages
    for (let p = 1; p <= totalPages; p++) {
      paths.push({ params: { category: slug, page: String(p) } })
    }
  }
  return paths
}

const slug = String(Astro.params.category)
const current = Number(Astro.params.page)

const entry = legacy.taxonomies.categories[slug]
if (!entry) throw new Error(`Missing category: ${slug}`)
const urls = entry.pages ?? []
const items = urls.map((u) => legacy.pageByUrl.get(u)).filter(Boolean)
const zhItems = items.filter((p) => p?.lang === 'zh')
const enItems = items.filter((p) => p?.lang === 'en')
const { totalPages: zhTotal } = paginate(zhItems, pageSize)
const { totalPages: enTotal } = paginate(enItems, pageSize)
const zhList = slicePage(zhItems, pageSize, current)
const enList = slicePage(enItems, pageSize, current)
---

<BaseLayout
  title={entry.name}
  urlPath={current <= 1 ? `/categories/${slug}/` : `/categories/${slug}/page/${current}/`}
>
  <div class="xw-container xw-page">
    <header class="xw-page-head">
      <p class="xw-eyebrow">Category</p>
      <h1 class="xw-page-title">{entry.name}</h1>
    </header>
    <LangPanes
      zhList={zhList}
      enList={enList}
      zhTotal={zhTotal}
      enTotal={enTotal}
      current={current}
      hrefForPage={(page) =>
        page <= 1 ? `/categories/${slug}/` : `/categories/${slug}/page/${page}/`}
    />
  </div>
</BaseLayout>
