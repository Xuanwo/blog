---
export const prerender = true

import BaseLayout from '../layouts/BaseLayout.astro'
import LangPanes from '../components/LangPanes.astro'
import { loadContentIndex } from '../lib/site-data'
import { paginate, slicePage } from '../lib/pagination'

const { site, pages } = await loadContentIndex()
const pageSize = site.pagination ?? 10

const regularPages = pages.filter((p) => p.type !== 'page')
const zhPages = regularPages.filter((p) => p.lang === 'zh')
const enPages = regularPages.filter((p) => p.lang === 'en')
const current = 1
const { totalPages: zhTotal } = paginate(zhPages, pageSize)
const { totalPages: enTotal } = paginate(enPages, pageSize)
const zhList = slicePage(zhPages, pageSize, current)
const enList = slicePage(enPages, pageSize, current)
const description = site.params.description ?? ''
---

<BaseLayout title={site.title} urlPath="/">
  <div class="xw-container xw-home">
    <header class="xw-home__hero">
      <div data-lang-pane="zh">
        <h1 class="xw-home__title">{site.i18nZh.site_title ?? site.title}</h1>
        <p class="xw-home__sub">{site.i18nZh.site_description ?? description}</p>
      </div>
      <div data-lang-pane="en">
        <h1 class="xw-home__title">{site.title}</h1>
        <p class="xw-home__sub">{description}</p>
      </div>
    </header>
    <LangPanes
      zhList={zhList}
      enList={enList}
      zhTotal={zhTotal}
      enTotal={enTotal}
      current={current}
      hrefForPage={(page) => (page <= 1 ? '/' : `/page/${page}/`)}
    />
  </div>
</BaseLayout>

<style>
  .xw-home { padding-top: var(--space-8); padding-bottom: var(--space-7); }
  .xw-home__hero { margin-bottom: var(--space-6); }
  .xw-home__title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    margin-top: var(--space-2);
    color: var(--fg);
  }
  .xw-home__sub {
    font-size: var(--text-lg);
    color: var(--fg-muted);
    margin-top: var(--space-3);
    line-height: var(--leading-relaxed);
    max-width: 640px;
  }
  .xw-home__sub-cn { color: var(--fg-subtle); margin-left: 0.5ch; }
</style>
